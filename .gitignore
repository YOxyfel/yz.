# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local scratch / audits (never commit)
.tmp-*
.tmp-lh/
lighthouse-*.json

# typescript
*.tsbuildinfo
next-env.d.ts

# large 3D source assets — only the compressed *.draco.glb web files are committed
public/arsenal/models/character/**/*.fbx
public/arsenal/models/character/**/*.json
public/arsenal/models/character/**/textures/
public/arsenal/models/character/**/*.glb
!public/arsenal/models/character/**/*.draco.glb
